---
import { WHATSAPP } from "../data/site";
---

<section class="section contact" id="contacto">
  <div class="wrap">
    <span class="eyebrow reveal">Contacto</span>
    <h2 class="reveal" data-d="1">
      Más estructura, intención y <span class="mark"><span>detalle.</span></span
      >
    </h2>
    <div class="ask reveal" data-d="2">¿Armamos tu web?</div>
    <a
      class="btn reveal"
      data-d="3"
      href={WHATSAPP}
      target="_blank"
      rel="noopener"
    >
      Escríbeme por Whatsapp <span class="arr">→</span>
    </a>
  </div>
</section>
