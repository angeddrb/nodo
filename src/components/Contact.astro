---
import Button from "./Button.astro";
import { WHATSAPP } from "../data/site";
---

<section class="py-12 md:py-20 lg:py-24" id="contacto">
  <div class="wrap">
    <span class="eyebrow reveal">Contacto</span>

    <h2
      class="reveal mt-4 max-w-[13ch] text-4xl font-normal leading-[1.05] tracking-tight md:text-5xl lg:text-6xl xl:text-7xl"
      data-d="1"
    >
      Más estructura, intención y <span class="mark"><span>detalle.</span></span
      >
    </h2>

    <div
      class="reveal mt-1 text-4xl font-normal leading-[1.05] tracking-tight text-lime-500 md:text-5xl lg:text-6xl xl:text-7xl"
      data-d="2"
    >
      ¿Armamos tu web?
    </div>

    <div class="reveal mt-8" data-d="3">
      <Button href={WHATSAPP} />
    </div>
  </div>
</section>
