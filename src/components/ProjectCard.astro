---
import type { Project } from "../data/projects";
import { typeLabel } from "../data/projects";

interface Props {
  project: Project;
  logo: string; // SVG inline (string crudo)
  delay?: number;
  reveal?: boolean; // animación de aparición (en /proyectos la desactivamos)
}

const { project, logo, delay = 0, reveal = true } = Astro.props;
const badge = project.badge ?? typeLabel(project.type);
---

<a
  class:list={["project", reveal && "reveal"]}
  data-d={delay}
  data-type={project.type}
  href={project.href}
  target={"_blank"}
  style={`--bg:url('${project.image}')`}
  aria-label={`${project.title} — ${project.subtitle}`}
>
  <span class="badge">{badge}</span>
  {logo && <span class="watermark" set:html={logo} />}
  <div class="meta">
    <div class="ttl">{project.title}</div>
    <div class="sub">{project.subtitle}</div>
  </div>
  <span class="go" aria-hidden="true">
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
    >
      <path d="M7 17 17 7M9 7h8v8"></path>
    </svg>
  </span>
</a>
