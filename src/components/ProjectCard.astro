---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  logo: string; // SVG inline (string crudo)
  delay?: number;
}

const { project, logo, delay = 0 } = Astro.props;
---

<a
  class="project reveal"
  data-d={delay}
  href={project.href}
  target="_blank"
  style={`--bg:url('${project.image}')`}
  aria-label={`${project.title} — ${project.subtitle}`}
>
  <span class="badge">{project.badge}</span>
  <span class="watermark" set:html={logo} />
  <div class="meta">
    <div class="ttl">{project.title}</div>
    <div class="sub">{project.subtitle}</div>
  </div>
  <span class="go" aria-hidden="true">
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
    >
      <path d="M7 17 17 7M9 7h8v8"></path>
    </svg>
  </span>
</a>
