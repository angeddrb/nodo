---
import NodoLogo from "./NodoLogo.astro";
import Button from "./Button.astro";
import { WHATSAPP } from "../data/site";
---

<header class="site" id="top">
  <div class="wrap nav">
    <a
      class="brand [&_svg]:block [&_svg]:h-12 [&_svg]:w-auto"
      href="/"
      aria-label="Nodo — inicio"
    >
      <NodoLogo />
    </a>

    <nav class="nav-links" aria-label="Principal">
      <a class="navlink" href="/#que-hago">Que hago</a>
      <a class="navlink" href="/#proyectos">Proyectos</a>
      <a class="navlink" href="/#como-trabajo">Como trabajo</a>
      <Button href={WHATSAPP} />
    </nav>

    <Button href={WHATSAPP} label="Whatsapp" class="nav-toggle" />
  </div>
</header>
